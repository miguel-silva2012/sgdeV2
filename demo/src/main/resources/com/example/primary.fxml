<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import java.net.URL?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.PrimaryController">
   <stylesheets>
      <URL value="@css/style.css" />
   </stylesheets>

   <children>
      <HBox spacing="10.0" alignment="CENTER">
         <Label text="Name: " />

         <TextField fx:id="nameField" 
                  promptText="Say the name of the product..." 
                  maxWidth="250.0"/>

         <Label text="Price: " />

         <TextField fx:id="priceField" 
            promptText="Say the price of the product..." 
            maxWidth="250.0"/>         
      </HBox>

      <HBox spacing="10.0" alignment="CENTER">   
         <Label text="Quantity: " />

         <TextField fx:id="quantityField" 
            promptText="Say the quantity of the product..." 
            maxWidth="250.0"/>

         <Label text="Description: " />
         
         <TextField fx:id="descriptionField" 
            promptText="Say the description of the product..." 
            maxWidth="250.0"/>
      </HBox>      

      <Button text="Enter" onAction="#execute" />

      <Label text=" " fx:id="result" />

      <TableView fx:id="tableClothes" prefHeight="300.0" prefWidth="450.0">
         <columns>
            <TableColumn fx:id="columnName" prefWidth="70.0" text="Name" />
            <TableColumn fx:id="columnPrice" prefWidth="125.0" text="Price" />
            <TableColumn fx:id="columnQuantity" prefWidth="150.0" text="Quantity" />
            <TableColumn fx:id="columnDescription" prefWidth="200.0" text="Description" />
         </columns>
      </TableView>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
